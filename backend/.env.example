# ============================
# Serpynx Backend — Environment
# ============================

# Database (PostgreSQL connection string)
DATABASE_URL="postgresql://username:password@localhost:5432/serpynx?schema=public"

# JWT Authentication (REQUIRED — app will not start without these)
JWT_SECRET="generate-a-strong-256-bit-secret-here"
JWT_EXPIRATION="7d"

# App
PORT=3000
NODE_ENV=development

# Frontend URL (for CORS — required in production)
FRONTEND_URL="https://your-frontend-domain.com"

# Google OAuth (optional — needed for Google login)
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"

# Email / SMTP (optional — emails will be logged to console if not set)
SMTP_HOST="smtp.resend.com"
SMTP_PORT=587
SMTP_USER="resend"
SMTP_PASS="your-api-key"
SMTP_FROM="\"Serpynx\" <noreply@yourdomain.com>"
